{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install --legacy-peer-deps",
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/seo/sitemap"
    },
    {
      "source": "/product-feed.xml",
      "destination": "/api/seo/product-feed"
    },
    {
      "source": "/price-alerts.xml",
      "destination": "/api/seo/price-alerts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(self), camera=(self), interest-cohort=()" }
      ]
    },
    {
      "source": "/api/seo/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" },
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=7200" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/admin/kpis",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/boardroom/oracle-bridge",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/notifications/daily-digest",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/boardroom/scheduler?type=morning_briefing",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/boardroom/scheduler?type=standup",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/boardroom/scheduler?type=evening_debrief",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/argos-scan",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/aggregate-corrections",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/board-briefing",
      "schedule": "0 12 * * *"
    }
  ]
}